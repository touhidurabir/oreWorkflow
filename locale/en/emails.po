msgid "plugins.generic.oreWorkflow.emails.authorSubmissionFileNotify.subject"
msgstr "Author File Upload: {$submissionTitle}"

msgid "plugins.generic.oreWorkflow.emails.authorSubmissionFileNotify.body"
msgstr ""
"<p>Dear {$recipientName},</p>"
"<p>The author {$authorName} has uploaded a {$uploadType} file <b>{$fileName}</b> "
"to the submission <a href=\"{$submissionUrl}\">{$submissionTitle}</a>.</p>"
"<p>As an assigned editor, we ask that you login and "
"<a href=\"{$submissionUrl}\">view the submission</a>.</p>"
"<br><br>—<br>"
"This is an automated message from <a href=\"{$contextUrl}\">{$contextName}</a>."

msgid "plugins.generic.oreWorkflow.authorSubmissionFileNotify.description"
msgstr ""
"This email is sent automatically to editors when an author uploads a new "
"file or revision to the submission stage."

msgid "plugins.generic.oreWorkflow.emailVariable.uploadType"
msgstr "Whether this is a new file upload or a revision (e.g. \"new\" or \"revision\")"

msgid "plugins.generic.oreWorkflow.emailVariable.uploadType.new"
msgstr "new"

msgid "plugins.generic.oreWorkflow.emailVariable.uploadType.revision"
msgstr "revision"
